node_modules
dist
coverage
*.log

# Local env (real Supabase credentials live here, never in the repo).
.env.local
.env*.local

# Per-task, machine-local scope. Regenerated by `pnpm scope`.
.task/allowed-files.json

# Per-project run ledger.
edit-log.jsonl

# One-time "no scope active" acknowledgement marker (scope-guard hook).
.task/.unscoped-ack

# Latest verify failure snapshot (verify --agent).
.task/last-verify.json

# Stryker mutation-test sandbox (pnpm mutation).
.stryker-tmp
reports

# Per-task, machine-local branch name. Regenerated by `pnpm scope`.
.task/branch

# Per-task spec and PR body. Rewritten each task at a fixed path, so tracking
# them guarantees merge conflicts between parallel branches; the spec ships
# inside the PR body instead (feature pipeline, Stage 5).
.task/spec.md
.task/pr-body.md

# Live git worktrees (agent isolation + local merges). Never commit these.
.claude/worktrees/

# Generated image scratch (mcp-image tool output; regenerable, never the deliverable).
output/
