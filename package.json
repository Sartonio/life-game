{
  "name": "ai-first-starter",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.9.0",
  "engines": {
    "node": ">=22.18"
  },
  "scripts": {
    "prepare": "lefthook install || true",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:framework": "vitest run --config vitest.framework.config.ts",
    "coverage": "vitest run --coverage",
    "knip": "knip",
    "mutation": "stryker run",
    "verify": "node scripts/verify.ts",
    "new-module": "node scripts/new-module.ts",
    "scope": "node scripts/scope.ts",
    "init:project": "node scripts/init.ts",
    "edit-log": "node scripts/edit-log.ts",
    "pr": "node scripts/pr.ts",
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview"
  },
  "devDependencies": {
    "@eslint/js": "^9.15.0",
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/vitest-runner": "^9.6.1",
    "@types/node": "^22.10.1",
    "@vitest/coverage-v8": "^2.1.8",
    "eslint": "^9.15.0",
    "eslint-plugin-boundaries": "^5.0.1",
    "fast-check": "^4.8.0",
    "happy-dom": "^20.10.6",
    "knip": "^5.39.2",
    "lefthook": "^1.8.4",
    "prettier": "^3.4.1",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.16.0",
    "vite": "^6.0.2",
    "vitest": "^2.1.8"
  },
  "dependencies": {
    "pixi-viewport": "^6.0.3",
    "pixi.js": "^8.19.0"
  }
}
