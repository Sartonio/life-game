{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "entry": [
    "scripts/*.ts",
    ".claude/hooks/*.ts",
    "api/coach.ts",
    "src/modules/*/index.ts",
    "src/modules/*/__tests__/**/*.ts",
    "test/**/*.test.ts"
  ],
  "project": [
    "src/**/*.ts",
    "scripts/**/*.ts",
    ".claude/hooks/**/*.ts",
    "test/**/*.ts",
    "api/**/*.ts"
  ],
  "ignoreDependencies": ["vite"]
}
